# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build output — generated by `npm run build`, never commit
_site/
dist/

# Eleventy
.cache/
.eleventy.cache/

# Environment / secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/

# Test & verification artifacts
coverage/
.nyc_output/
/screenshots/
/screenshots-baseline/
/screenshots-diff/
playwright-report/
test-results/

# Playwright snapshots ARE committed — they are the migration's proof of
# visual neutrality. Only transient run artifacts are ignored.
!tests/**/*-snapshots/

# Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

.superpowers/

# Claude Code — personal settings, never committed
.claude/settings.local.json

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

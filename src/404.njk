---
layout: layouts/base.njk
permalink: /404.html
robots: 'noindex, follow'
pageKey: 'home'
lang: 'de'
eleventyComputed:
  title: 'Seite nicht gefunden — BlitzBlank'
  description: 'Die gesuchte Seite wurde verschoben oder existiert nicht mehr. Zurück zur Startseite oder zu den Leistungen.'
---
{#
  Deliberately NOT paginated per language, unlike every other page.

  A static host serves one error document for the whole origin and cannot
  negotiate a language for it, so /404.html is emitted once in German (the
  root language) with an English sub-heading and links to both language homes.
  It stays noindex.

  `pageKey: home` is set only so the layout's canonical/hreflang/lang-switch
  have something to resolve against — the page itself is noindex, so those
  tags carry no SEO weight here.
#}
{% set d = dict.de %}
{% set en = dict.en %}
  <main id="main" class="error-page">
    <div class="error-page__content">
      <div class="error-page__code" aria-hidden="true">{{ 'error.code' | t(d) }}</div>
      <h1>{{ 'error.title' | t(d) }}</h1>
      <p lang="en" class="error-page__alt">{{ 'error.title' | t(en) }}</p>
      <p>{{ 'error.desc' | t(d) }}</p>

      <div class="error-page__actions">
        <a href="{{ 'home' | url('de') }}" class="btn btn--primary btn--lg">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9.5 12 3l9 6.5V21a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/><path d="M9 22V12h6v10"/></svg>
          {{ 'error.btn1' | t(d) }}
        </a>
        <a href="{{ 'services' | url('de') }}" class="btn btn--outline btn--lg">{{ 'error.btn2' | t(d) }}</a>
        <a href="{{ 'contact' | url('de') }}" class="btn btn--outline btn--lg">{{ 'error.btn3' | t(d) }}</a>
      </div>

      <div class="error-page__suggest">
        <span class="error-page__suggest-label">{{ 'error.suggest' | t(d) }}</span>
        <nav class="error-page__suggest-links" aria-label="{{ 'error.suggest' | t(d) }}">
          <a href="{{ 'contact' | url('de') }}#about">{{ 'error.suggest.about' | t(d) }} →</a>
          <a href="{{ 'gallery' | url('de') }}">{{ 'error.suggest.gallery' | t(d) }} →</a>
          <a href="{{ 'home' | url('de') }}#reviews">{{ 'error.suggest.reviews' | t(d) }} →</a>
          <a href="{{ 'home' | url('de') }}#faq">{{ 'error.suggest.faq' | t(d) }} →</a>
        </nav>
        <a class="error-page__lang-hint" href="{{ 'home' | url('en') }}" lang="en" hreflang="en">Looking for the English site? →</a>
      </div>
    </div>
  </main>

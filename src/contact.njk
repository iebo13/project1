title: 'Kontakt — BlitzBlank Düsseldorf'
description: 'Kontaktieren Sie BlitzBlank für ein kostenloses, unverbindliches Reinigungsangebot. Telefon, E-Mail oder Formular — Antwort innerhalb eines Werktages.'
navbarSolid: true
---
  <main id="main">
    <section class="page-hero">
      <div class="page-hero__bg" aria-hidden="true"><img src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?auto=format&fit=crop&w=1920&q=80" alt="" loading="eager" /></div>
      <div class="container page-hero__content">
        <span class="eyebrow eyebrow--light" style="margin-bottom: var(--space-5)"><span class="eyebrow__dot"></span>Say Hello</span>
        <h1>Let's make your space immaculate.</h1>
        <p>Tell us what you need. We'll send a personalised quote within one business day — no pushy salespeople, no obligation.</p>
        <nav class="breadcrumb" aria-label="Breadcrumb"><a href="index.html"><span data-i18n="nav.home">Home</span></a><span class="breadcrumb__sep">/</span><span>Contact</span></nav>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="contact-cta">
          <!-- LEFT: Info -->
          <div class="contact-cta__info" data-reveal="left">
            <span class="eyebrow"><span class="eyebrow__dot"></span>Contact Details</span>
            <h2 style="margin-top: var(--space-4)">Real people, real fast responses.</h2>
            <p>Prefer to talk first? Call us, email us, or stop by the Königsallee-Zentrale. We answer every message ourselves — no chatbots, no offshore call centres.</p>

            <div class="contact-list">
              <div class="contact-list__item">
                <span class="contact-list__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </span>
                <div>
                  <div class="contact-list__label">Phone</div>
                  <a class="contact-list__value" href="tel:+4921193456789">+49 211 934 567 89</a>
                </div>
              </div>
              <div class="contact-list__item">
                <span class="contact-list__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </span>
                <div>
                  <div class="contact-list__label">Email</div>
                  <a class="contact-list__value" href="mailto:hallo@blitzblank.de">hallo@blitzblank.de</a>
                </div>
              </div>
              <div class="contact-list__item">
                <span class="contact-list__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </span>
                <div>
                  <div class="contact-list__label">Studio HQ</div>
                  <div class="contact-list__value">Königsallee 42<br/>40212 Düsseldorf</div>
                </div>
              </div>
              <div class="contact-list__item">
                <span class="contact-list__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </span>
                <div>
                  <div class="contact-list__label">Business Hours</div>
                  <div class="contact-list__value">Mon–Sat: 7:00 AM – 8:00 PM<br/>Sunday: Closed (emergencies only)</div>
                </div>
              </div>
            </div>

            <div class="contact-socials">
              <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
              <a href="#" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
              <a href="#" aria-label="Twitter"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2H21.5l-7.5 8.572L22.5 22h-6.928l-5.42-7.09L3.8 22H.543l8.022-9.17L1 2h7.1l4.9 6.49L18.244 2z"/></svg></a>
              <a href="#" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></a>
            </div>
          </div>

          <!-- RIGHT: Form -->
          <div class="contact-form-card" data-reveal="right">
            <h3 style="margin-bottom: var(--space-2)">Request your free quote</h3>
            <p style="color: var(--color-muted); margin-bottom: var(--space-6); font-size: var(--fs-sm);">Fields marked with * are required. We respond within one business day.</p>

            <form id="contact-form" novalidate>
              <div class="form-row">
                <div class="field">
                  <label class="field__label" for="firstName">First name *</label>
                  <input class="field__input" type="text" id="firstName" name="firstName" autocomplete="given-name" data-rules="required|minLength:2" data-min="2" required />
                  <span class="field__error" aria-live="polite"></span>
                </div>
                <div class="field">
                  <label class="field__label" for="lastName">Last name *</label>
                  <input class="field__input" type="text" id="lastName" name="lastName" autocomplete="family-name" data-rules="required|minLength:2" data-min="2" required />
                  <span class="field__error" aria-live="polite"></span>
                </div>
              </div>

              <div class="form-row">
                <div class="field">
                  <label class="field__label" for="email">Email *</label>
                  <input class="field__input" type="email" id="email" name="email" autocomplete="email" data-rules="required|email" required />
                  <span class="field__error" aria-live="polite"></span>
                </div>
                <div class="field">
                  <label class="field__label" for="phone">Phone</label>
                  <input class="field__input" type="tel" id="phone" name="phone" autocomplete="tel" data-rules="phone" />
                  <span class="field__error" aria-live="polite"></span>
                </div>
              </div>

              <div class="form-row form-row--single">
                <div class="field">
                  <label class="field__label" for="service">Service needed *</label>
                  <select class="field__select" id="service" name="service" data-rules="required" required>
                    <option value="">Please choose…</option>
                    <option value="office">Office Cleaning</option>
                    <option value="house">House Cleaning</option>
                    <option value="window">Window Cleaning</option>
                    <option value="industrial">Industrial Cleaning</option>
                    <option value="deep">Deep Cleaning</option>
                    <option value="moveout">Move-out Cleaning</option>
                    <option value="carpet">Carpet Cleaning</option>
                    <option value="restaurant">Restaurant Cleaning</option>
                    <option value="medical">Medical Cleaning</option>
                    <option value="construction">Construction Cleaning</option>
                    <option value="other">Other / Not sure</option>
                  </select>
                  <span class="field__error" aria-live="polite"></span>
                </div>
              </div>

              <div class="form-row form-row--single">
                <div class="field">
                  <label class="field__label" for="message">Tell us about your space *</label>
                  <textarea class="field__textarea" id="message" name="message" placeholder="Square footage, frequency, any specific concerns…" data-rules="required|minLength:10" data-min="10" required></textarea>
                  <span class="field__error" aria-live="polite"></span>
                </div>
              </div>

              <div class="form-row form-row--single">
                <div class="field" style="display:flex; align-items:flex-start; gap: var(--space-3); background: var(--color-bg); padding: var(--space-4); border-radius: var(--radius-md); flex-wrap: wrap;">
                  <input class="field__input" type="checkbox" id="consent" name="consent" data-rules="checked" style="margin-top:4px; width:18px; height:18px; flex: 0 0 auto; accent-color: var(--color-secondary);" required />
                  <label for="consent" style="font-size: var(--fs-sm); color: var(--color-muted); margin: 0; line-height: var(--lh-normal); flex: 1;">
                    I agree to be contacted about my request and accept the <a href="#" style="color: var(--color-secondary); text-decoration: underline;">privacy policy</a>. We never share your data.
                  </label>
                  <span class="field__error" aria-live="polite" style="flex: 0 0 100%;"></span>
                </div>
              </div>

              <button type="submit" class="btn btn--primary btn--block btn--lg" style="margin-top: var(--space-4);">
                Send my request
                <svg class="icon icon--arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>

              <div class="form-message" role="status" aria-live="polite"></div>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- Map -->
    <section class="section section--tight section--tinted">
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="eyebrow"><span class="eyebrow__dot"></span>Find Us</span>
          <h2 class="section-title">Our Königsallee-Zentrale</h2>
          <p class="section-subtitle">Drop by for a coffee, or schedule a tour of the studio where every clean begins.</p>
        </div>

        <div class="map-embed" data-reveal aria-label="Karte: BlitzBlank Zentrale an der Königsallee 42, Düsseldorf">
          <div class="map-embed__grid" aria-hidden="true"></div>
          <div class="map-embed__pin" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div class="map-embed__placeholder">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <h4>Königsallee 42</h4>
            <p>40212 Düsseldorf · Parkplätze in der Nähe</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ teaser -->
    <section class="section">
      <div class="container">
        <div class="promo-banner" data-reveal>
          <div class="promo-banner__content">
            <h2>Have a quick question first?</h2>
            <p>Browse our most-asked questions — we cover products, scheduling, guarantees, and more.</p>
            <div class="hero__cta" style="justify-content: center; opacity:1; animation: none;">
              <a href="index.html#faq" class="btn btn--primary btn--lg">Visit FAQ</a>
              <a href="services.html" class="btn btn--ghost-light btn--lg">View services</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

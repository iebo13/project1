<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0F172A" />

  <!-- Primary Meta Tags -->
  <title>{{ title }}</title>
  <meta name="title" content="BlitzBlank — Premium Reinigung in Düsseldorf" />
  <meta name="description" content="{{ description }}" />
  <meta name="keywords" content="Reinigung Düsseldorf, Reinigungsfirma, Büroreinigung, Privatreinigung, Tiefenreinigung, Fensterreinigung, Industriereinigung, Teppichreinigung" />
  <meta name="author" content="BlitzBlank" />
  {% if robots %}<meta name="robots" content="{{ robots }}" />{% endif %}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://blitzblank.de/" />
  <meta property="og:title" content="BlitzBlank — Premium Reinigung in Düsseldorf" />
  <meta property="og:description" content="Ausgezeichnete Reinigungsmanufaktur, der über 500 Kunden vertrauen. 100% Zufriedenheitsgarantie." />
  <meta property="og:image" content="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1200&q=80" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="BlitzBlank — Premium Reinigung in Düsseldorf" />
  <meta name="twitter:description" content="Ausgezeichnete Reinigungsmanufaktur, der über 500 Kunden vertrauen. 100% Zufriedenheitsgarantie." />
  <meta name="twitter:image" content="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1200&q=80" />

  <!-- Favicon (inline SVG) -->
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%232563EB'/%3E%3Cpath d='M50 18 L62 50 L78 50 L48 82 L58 56 L42 56 Z' fill='white'/%3E%3C/svg%3E" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Styles -->
  <link rel="stylesheet" href="css/variables.css" />
  <link rel="stylesheet" href="css/animations.css" />
  <link rel="stylesheet" href="css/components.css" />
  <link rel="stylesheet" href="css/style.css" />
  <link rel="stylesheet" href="css/responsive.css" />

  <!-- Structured Data -->
  <script type="application/ld+json">
  {% raw %}
  {
    "@context": "https://schema.org",
    "@type": "CleaningService",
    "name": "BlitzBlank",
    "image": "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1200&q=80",
    "description": "Premium Reinigungsmanufaktur für Privatkunden und Unternehmen in Düsseldorf.",
    "telephone": "+49-211-934-567-89",
    "email": "hallo@blitzblank.de",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Königsallee 42",
      "addressLocality": "Düsseldorf",
      "addressRegion": "NRW",
      "postalCode": "40212",
      "addressCountry": "DE"
    },
    "openingHours": "Mo-Sa 07:00-20:00",
    "priceRange": "€€€",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.9",
      "reviewCount": "528"
    }
  }
  {% endraw %}
  </script>
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
  <a href="#main" class="skip-link">Skip to main content</a>

  <!-- Preloader -->
  <div class="preloader" aria-hidden="true">
    <div class="preloader__ring"></div>
    <div class="preloader__brand">BlitzBlank</div>
  </div>

  <!-- ===== NAVBAR ===== -->
{% include "partials/navbar.njk" %}

  {{ content | safe }}

  <!-- ===== FOOTER ===== -->
{% include "partials/footer.njk" %}

  <!-- Back to top -->
  <button class="back-to-top" data-i18n-aria="footer.backToTop" aria-label="Back to top">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
  </button>

  <!-- ===== SCRIPTS ===== -->
  <script src="js/i18n.js" defer></script>
  <script src="js/animations.js" defer></script>
  <script src="js/navigation.js" defer></script>
  <script src="js/counter.js" defer></script>
  <script src="js/faq.js" defer></script>
  <script src="js/slider.js" defer></script>
  <script src="js/gallery.js" defer></script>
  <script src="js/contact.js" defer></script>
  <script src="js/app.js" defer></script>
</body>
</html>

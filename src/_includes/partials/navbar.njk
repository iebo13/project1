{% set d = dict[lang] %}
  <header class="navbar" id="navbar">
    <div class="navbar__inner">
      <a href="{{ 'home' | url(lang) }}" class="logo" aria-label="{{ site.brand }} — {{ 'nav.home' | t(d) }}">
        <span class="logo__mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 2 L4.5 12.5 H11 L9 22 L19.5 10.5 H13 Z" fill="currentColor" stroke="none"/>
          </svg>
        </span>
        <span class="logo__text">
          <span class="logo__name">{{ site.brand }}</span>
          <span class="logo__tag">{{ 'logo.tag' | t(d) }}</span>
        </span>
      </a>

      <nav class="nav-menu" id="navMenu" aria-label="{{ 'nav.home' | t(d) }}">
        {% for item in site.nav | selectattr('inHeader') %}
        <a href="{{ item.page | url(lang) }}{{ item.hash or '' }}" class="nav-link"{% if item.page == pageKey and not item.hash %} aria-current="page"{% endif %}><span>{{ item.key | t(d) }}</span><span class="nav-link__underline"></span></a>
        {% endfor %}
      </nav>

      <div class="navbar__actions">
        {# Real links to this page's counterpart in the other language, not JS
           buttons. hreflang tells the browser (and crawlers) what they point
           at; aria-current marks the active one. #}
        <div class="lang-switch" role="group" aria-label="{{ 'nav.lang' | t(d) }}">
          {% for code in langs.codes %}
          <a class="lang-switch__btn{% if code == lang %} is-active{% endif %}"
             href="{{ pageKey | url(code) }}"
             hreflang="{{ code }}"
             lang="{{ code }}"
             {% if code == lang %}aria-current="true"{% endif %}>{{ code | upper }}</a>
          {% endfor %}
        </div>

        <a href="{{ site.phoneHref }}" class="navbar__phone">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {{ site.phone }}
        </a>
        <a href="{{ 'contact' | url(lang) }}" class="btn btn--primary btn--sm" data-magnetic><span>{{ 'nav.cta' | t(d) }}</span></a>
        <button class="nav-toggle" id="navToggle" aria-label="{{ 'nav.menu' | t(d) }}" aria-expanded="false" aria-controls="navDrawer" aria-haspopup="dialog">
          <span class="nav-toggle__bar"></span>
          <span class="nav-toggle__bar"></span>
          <span class="nav-toggle__bar"></span>
        </button>
      </div>
    </div>
  </header>

  {# Mobile drawer: a native <dialog> — showModal() supplies focus trapping,
     ESC, focus restore and ::backdrop, same platform-first move as the
     lightbox. Sibling of the header, not a child: top-layer promotion is
     cleaner without a fixed, filtered ancestor in the chain. Closed on
     desktop; the burger that opens it only renders ≤1279px. #}
  <dialog class="nav-drawer" id="navDrawer" aria-label="{{ 'nav.menuLabel' | t(d) }}">
    <div class="nav-drawer__head">
      <span class="nav-drawer__brand" aria-hidden="true">
        <span class="logo__mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 2 L4.5 12.5 H11 L9 22 L19.5 10.5 H13 Z" fill="currentColor" stroke="none"/>
          </svg>
        </span>
        <span class="nav-drawer__brand-name">{{ site.brand }}</span>
      </span>
      <button class="nav-drawer__close" aria-label="{{ 'nav.close' | t(d) }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    {# The full nav list, anchors included — the drawer has the room the
       header row lacks; same set and order as the footer's quick links. #}
    <nav class="nav-drawer__nav" aria-label="{{ 'nav.menuLabel' | t(d) }}">
      {% for item in site.nav %}
      <a href="{{ item.page | url(lang) }}{{ item.hash or '' }}" class="nav-drawer__link" style="--i: {{ loop.index0 }}"{% if item.page == pageKey and not item.hash %} aria-current="page"{% endif %}>{{ item.key | t(d) }}</a>
      {% endfor %}
    </nav>

    <div class="nav-drawer__foot">
      <div class="lang-switch" role="group" aria-label="{{ 'nav.lang' | t(d) }}">
        {% for code in langs.codes %}
        <a class="lang-switch__btn{% if code == lang %} is-active{% endif %}"
           href="{{ pageKey | url(code) }}"
           hreflang="{{ code }}"
           lang="{{ code }}"
           {% if code == lang %}aria-current="true"{% endif %}>{{ code | upper }}</a>
        {% endfor %}
      </div>
      <a href="{{ site.phoneHref }}" class="nav-drawer__phone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {{ site.phone }}
      </a>
      <a href="{{ 'contact' | url(lang) }}" class="btn btn--primary nav-drawer__cta"><span>{{ 'nav.cta' | t(d) }}</span></a>
    </div>
  </dialog>

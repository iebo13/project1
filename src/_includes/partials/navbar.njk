  <header class="navbar{% if navbarSolid %} navbar--solid{% endif %}" id="navbar">
    <div class="navbar__inner">
      <a href="index.html" class="logo" aria-label="BlitzBlank — Startseite">
        <span class="logo__mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 2 L4.5 12.5 H11 L9 22 L19.5 10.5 H13 Z" fill="currentColor" stroke="none"/>
          </svg>
        </span>
        <span class="logo__text">
          <span class="logo__name">{{ site.brand }}</span>
          <span class="logo__tag" data-i18n="logo.tag">{{ site.tagline }}</span>
        </span>
      </a>

      <nav class="nav-menu" id="navMenu" aria-label="Main navigation">
        {% for item in site.nav %}
        <a href="{{ item.href }}" class="nav-link"><span data-i18n="{{ item.key }}">{{ item.label }}</span><span class="nav-link__underline"></span></a>
        {% endfor %}
      </nav>

      <div class="navbar__actions">
        <!-- Language Switcher -->
        <div class="lang-switch" role="group" aria-label="Language">
          <button class="lang-switch__btn" data-lang="en" aria-pressed="true">EN</button>
          <button class="lang-switch__btn" data-lang="de" aria-pressed="false">DE</button>
        </div>

        <a href="{{ site.phoneHref }}" class="navbar__phone">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          {{ site.phone }}
        </a>
        <a href="contact.html" class="btn btn--primary btn--sm" data-magnetic><span data-i18n="nav.cta">Get a Quote</span></a>
        <button class="nav-toggle" id="navToggle" data-i18n-aria="nav.menu" aria-label="Toggle menu" aria-expanded="false" aria-controls="navMenu">
          <span class="nav-toggle__bar"></span>
          <span class="nav-toggle__bar"></span>
          <span class="nav-toggle__bar"></span>
        </button>
      </div>
    </div>
  </header>

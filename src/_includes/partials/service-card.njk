{% if variant == 'home' %}
          <article class="service-card" data-tilt>
            <div class="service-card__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">{{ (service.homeIcon if service.homeIcon else service.icon) | safe }}</svg>
            </div>
            <h3 class="service-card__title" data-i18n="srv.{{ service.id }}.title">{{ service.title }}</h3>
            <p class="service-card__desc" data-i18n="srv.{{ service.id }}.desc">{{ service.homeBlurb }}</p>
            <a href="services.html#{{ service.id }}" class="service-card__link"><span data-i18n="services.link.all">Learn more</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </article>
{% else %}
          <article class="service-card" id="{{ service.id }}" data-tilt>
            <div class="service-card__icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">{{ service.icon | safe }}</svg></div>
            <h3 class="service-card__title">{{ service.title }}</h3>
            <p class="service-card__desc">{{ service.blurb }}</p>
            <a href="#{{ service.detailId }}" class="service-card__link">View details <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
          </article>
{% endif %}

{% set d = dict[lang] %}
  <footer class="footer" aria-label="Footer">
    <div class="container footer__inner">
      <div class="footer__top">
        <div class="footer__brand">
          <a href="{{ 'home' | url(lang) }}" class="logo">
            <span class="logo__mark" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 L4.5 12.5 H11 L9 22 L19.5 10.5 H13 Z" fill="currentColor" stroke="none"/></svg>
            </span>
            <span class="logo__text">
              <span class="logo__name logo__name--light">{{ site.brand }}</span>
              <span class="logo__tag">{{ 'logo.tag' | t(d) }}</span>
            </span>
          </a>
          <p class="footer__about">{{ 'footer.about' | t(d) }}</p>
          <div class="footer__socials">
            <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>
            <a href="#" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
            <a href="#" aria-label="Twitter"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2H21.5l-7.5 8.572L22.5 22h-6.928l-5.42-7.09L3.8 22H.543l8.022-9.17L1 2h7.1l4.9 6.49L18.244 2z"/></svg></a>
            <a href="#" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></a>
          </div>
        </div>

        <div class="footer__col">
          <h5>{{ 'footer.quickLinks' | t(d) }}</h5>
          <nav class="footer__links">
            {% for item in site.nav %}
            <a href="{{ item.page | url(lang) }}{{ item.hash or '' }}">{{ item.key | t(d) }}</a>
            {% endfor %}
          </nav>
        </div>

        <div class="footer__col">
          <h5>{{ 'footer.services' | t(d) }}</h5>
          <nav class="footer__links">
            {% for service in services | selectattr('onHome') | sort(attribute='homeOrder') %}
            <a href="{{ 'services' | url(lang) }}#{{ service.id }}">{{ ('srv.' + service.id + '.title') | t(d) }}</a>
            {% endfor %}
          </nav>
        </div>

        <div class="footer__col footer__newsletter">
          <h5>{{ 'footer.newsletter' | t(d) }}</h5>
          <p>{{ 'footer.newsletterDesc' | t(d) }}</p>
          <form class="newsletter-form" aria-label="{{ 'footer.newsletter' | t(d) }}"
                data-invalid="{{ 'form.toast.invalid' | t(d) }}"
                data-subscribed="{{ 'form.toast.subscribed' | t(d) }}">
            <input type="email" name="email" placeholder="{{ 'footer.placeholder' | t(d) }}" aria-label="{{ 'footer.placeholder' | t(d) }}" required />
            <button type="submit" aria-label="{{ 'footer.subscribe' | t(d) }}">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
          </form>
          <div class="footer__contact">
            <div>{{ 'contact.phone.label' | t(d) }}: {{ site.phone }}</div>
            <div>{{ 'contact.email.label' | t(d) }}: {{ site.email }}</div>
            <div>{{ site.address }}</div>
          </div>
        </div>
      </div>

      <div class="footer__bottom">
        <div>&copy; <span data-year>2025</span> {{ 'footer.rights' | t(d) }}</div>
        <div class="footer__legal">
          <a href="{{ 'imprint' | url(lang) }}">{{ 'footer.imprint' | t(d) }}</a>
          <a href="{{ 'privacy' | url(lang) }}">{{ 'footer.privacy' | t(d) }}</a>
        </div>
      </div>
    </div>
  </footer>
